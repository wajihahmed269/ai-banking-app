[Unit]
Description=Phoenix-Ops Remediation Webhook
After=network.target

[Service]
WorkingDirectory=/home/ubuntu/ai-banking-app
Environment=PORT=9090
ExecStart=/home/ubuntu/ai-banking-app/phoenix-ops/webhook/.venv/bin/python3 /home/ubuntu/ai-banking-app/phoenix-ops/webhook/remediation-webhook.py
Restart=always
RestartSec=5
User=ubuntu

[Install]
WantedBy=multi-user.target
